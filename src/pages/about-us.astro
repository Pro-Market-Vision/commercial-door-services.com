---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Commercial Door Services | Orlando & Miami Experts"
  description="About Commercial Door Services — your trusted commercial door experts in Orlando & Miami. Automatic doors, security doors & fire-rated doors. Call (954) 727-5435."
>
  <section class="relative bg-primary text-white py-20 md:py-24">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">About Commercial Door Services</h1>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Your Trusted Commercial Door Experts</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          Commercial Door Services is your premier provider of top-notch commercial door solutions in Orlando and Miami. With years of experience, we specialize in <a href="/contact" class="text-accent hover:underline">installation, repair, and maintenance</a> of commercial doors.
        </p>
        <p class="text-gray-600 leading-relaxed mb-4">
          Our key service areas include automatic door systems, fire-rated doors, and high-speed doors. Customer satisfaction is at the heart of our business. We pride ourselves on our fast response times, professional service, and competitive pricing.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Services include quick repairs, complete door replacements, and routine maintenance to keep your business secure and operational.
        </p>
      </div>
      <div>
        <img src="/images/services/installation.webp" alt="Commercial door installation service by our expert team in Orlando" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">What Our Clients Say</h2>
      <p class="text-gray-600">We provide top-tier commercial door services backed by excellent client reviews. From <a href="/" class="text-accent hover:underline">installation through repair</a>, our customers trust us for reliable, professional service every time.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Get Your Free Commercial Door Estimate</h2>
        <p class="text-gray-600 leading-relaxed">Upgrade your business with top-notch commercial door services. From installation to maintenance, our expert team ensures your doors are secure and efficient.</p>
      </div>
      <form id="contact-form" class="space-y-4 bg-gray-light p-8 rounded-lg" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
        <input type="hidden" name="subject" value="New Contact Form - Commercial Door Services" />
        <input type="hidden" name="from_name" value="Commercial Door Services Website" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
        <input type="hidden" name="recaptcha_response" id="recaptchaResponse" />
        <input type="text" name="name" placeholder="Name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <input type="tel" name="phone" placeholder="Phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <input type="email" name="email" placeholder="Email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <textarea name="message" placeholder="Message" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent resize-vertical"></textarea>
        <button id="submit-btn" type="submit" class="w-full bg-accent text-white font-heading text-xl tracking-wide py-4 rounded-lg hover:bg-blue-800 transition-colors">SEND</button>
        <div id="form-result" class="text-center text-sm mt-2 hidden"></div>
      </form>
      <script>
        const RECAPTCHA_SITE_KEY = 'YOUR_RECAPTCHA_SITE_KEY';
        const script = document.createElement('script');
        script.src = `https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`;
        document.head.appendChild(script);

        const form = document.getElementById('contact-form');
        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = document.getElementById('submit-btn');
          const result = document.getElementById('form-result');
          btn.textContent = 'SENDING...';
          btn.disabled = true;
          try {
            if (window.grecaptcha) {
              const token = await window.grecaptcha.execute(RECAPTCHA_SITE_KEY, { action: 'submit' });
              document.getElementById('recaptchaResponse').value = token;
            }
            const response = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) });
            const data = await response.json();
            if (data.success) {
              result.textContent = 'Thank you! Your message has been sent successfully.';
              result.className = 'text-center text-sm mt-2 text-green-600';
              result.classList.remove('hidden');
              form.reset();
            } else {
              result.textContent = 'Something went wrong. Please try again or call us directly.';
              result.className = 'text-center text-sm mt-2 text-red-600';
              result.classList.remove('hidden');
            }
          } catch {
            result.textContent = 'Something went wrong. Please try again or call us directly.';
            result.className = 'text-center text-sm mt-2 text-red-600';
            result.classList.remove('hidden');
          }
          btn.textContent = 'SEND';
          btn.disabled = false;
        });
      </script>
    </div>
  </section>
</Layout>
