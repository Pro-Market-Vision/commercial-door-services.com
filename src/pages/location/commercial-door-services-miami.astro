      { "@type": "Question", "name": "Which Miami neighborhoods do you serve?", "acceptedAnswer": { "@type": "Answer", "text": "We serve all of Miami-Dade — including Brickell, Downtown Miami, Wynwood, the Design District, Edgewater, Coral Gables, Coconut Grove, Doral, Hialeah, Aventura, Sunny Isles, Bal Harbour, Surfside, Miami Beach (South, Mid, and North), Key Biscayne, Pinecrest, Kendall, South Miami, the MIA airport corridor, and points along I-95, US-1, the Palmetto, and the Dolphin Expressway." } },
      { "@type": "Question", "name": "Do you install Miami-Dade NOA-approved hurricane-impact commercial doors?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We install Miami-Dade County NOA (Notice of Acceptance) approved hurricane-impact storefront systems, wind-rated hollow metal frames, and laminated glazing assemblies designed for the High-Velocity Hurricane Zone (HVHZ). This is required code in Miami-Dade and a smart upgrade everywhere else in South Florida." } },
      { "@type": "Question", "name": "How does Miami salt air affect commercial doors?", "acceptedAnswer": { "@type": "Answer", "text": "Severely. Salt-laden coastal air corrodes ferrous hardware — closers, hinges, lock cylinders, and threshold plates — in months rather than years if the wrong materials are specified. We default to stainless steel and aluminum components on coastal exposures, use marine-grade finishes, and apply protective coatings on door frames where appropriate." } },
      { "@type": "Question", "name": "Are your installations Florida Building Code, HVHZ, and ADA compliant?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every install is performed to current Florida Building Code, Miami-Dade HVHZ requirements, the International Building Code, NFPA 80 for fire-rated assemblies, and ADA accessibility requirements — including operator force, opening speed, threshold height, and clear-opening width." } },
      { "@type": "Question", "name": "Do you handle annual fire-door inspections?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. NFPA 80 requires annual inspection and documentation of all fire-rated door assemblies. We perform the inspection, generate compliance documentation, and complete corrective repairs in a single visit when possible — common for Miami-Dade County Public Schools, hotels, healthcare buildings, and multi-tenant office towers." } },
      { "@type": "Question", "name": "What commercial door brands do you service in Miami?", "acceptedAnswer": { "@type": "Answer", "text": "We service all major commercial brands including LCN, Norton, Sargent, Von Duprin, Yale, Schlage, Best, Corbin Russwin, Stanley, Besam/Assa Abloy automatic operators, Horton, Record, and rolling steel from Cornell, Cookson, and Wayne Dalton." } }
    ]
  })} />
</Layout>
