---
const navItems = [
  { name: "Home", href: "/" },
  { name: "About Us", href: "/about-us" },
  { name: "Services", href: "/#services" },
  { name: "Locations", href: "#" },
  { name: "Blog", href: "/blog" },
  { name: "Contact", href: "/contact" },
];

const serviceLinks = [
  { name: "Roller Replacement & Frame Repair", href: "/service/roller-replacement-and-frame-repair" },
  { name: "Lock Repair", href: "/service/lock-repair" },
  { name: "Hinge Repair/Replacement", href: "/service/hinge-repair-replacement" },
  { name: "Commercial Door Installation", href: "/service/commercial-door-installation" },
  { name: "Commercial Door Repair", href: "/service/commercial-door-repair" },
  { name: "Commercial Door Lock Services", href: "/service/commercial-door-lock-services" },
];

const locationLinks = [
  { name: "Orlando", href: "/location/commercial-door-services-orlando" },
  { name: "Miami", href: "/location/commercial-door-services-miami" },
  { name: "Denver", href: "/location/commercial-door-services-denver" },
];
---

<div class="bg-primary text-white text-sm py-2">
  <div class="max-w-7xl mx-auto px-4 flex justify-end items-center gap-4">
    <span>Serving Orlando & Miami, FL · Denver, CO</span>
    <a href="tel:9547275435" class="hover:underline font-semibold" aria-label="Call Commercial Door Services">(954) 727-5435</a>
  </div>
</div>

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-24">
    <a href="/" class="flex-shrink-0">
      <img src="/images/logo.png" alt="Commercial Door Services - Expert Installation & Repair in Orlando, Miami & Denver" class="h-20 w-auto" />
    </a>

    <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
      {navItems.map((item) => (
        item.name === "Services" ? (
          <div class="relative group">
            <a href={item.href} class="font-heading text-lg tracking-wide text-primary hover:text-accent py-2 inline-flex items-center gap-1">
              {item.name.toUpperCase()}
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </a>
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-lg shadow-xl border border-gray-100 py-2 min-w-[280px]">
                {serviceLinks.map((link) => (
                  <a href={link.href} class="block px-5 py-2.5 text-sm text-gray-700 hover:bg-primary/5 hover:text-accent transition-colors">{link.name}</a>
                ))}
              </div>
            </div>
          </div>
        ) : item.name === "Locations" ? (
          <div class="relative group">
            <a href={item.href} class="font-heading text-lg tracking-wide text-primary hover:text-accent py-2 inline-flex items-center gap-1">
              {item.name.toUpperCase()}
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </a>
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-lg shadow-xl border border-gray-100 py-2 min-w-[200px]">
                {locationLinks.map((link) => (
                  <a href={link.href} class="block px-5 py-2.5 text-sm text-gray-700 hover:bg-primary/5 hover:text-accent transition-colors">{link.name}</a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.href} class="font-heading text-lg tracking-wide text-primary hover:text-accent py-2">{item.name.toUpperCase()}</a>
        )
      ))}
    </nav>

    <a href="tel:9547275435" class="hidden lg:inline-flex bg-accent text-white font-heading text-lg tracking-wide px-6 py-3 rounded hover:bg-blue-800 transition-colors" aria-label="Call now for a free estimate">CALL NOW</a>

    <button id="mobile-menu-btn" class="lg:hidden p-2" aria-label="Open navigation menu">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100">
    <div class="px-4 py-4 space-y-3">
      {navItems.map((item) => (
        item.name === "Services" ? (
          <div>
            <button class="mobile-dropdown-btn w-full flex items-center justify-between font-heading text-lg tracking-wide text-primary py-2" data-target="mobile-services">
              {item.name.toUpperCase()}
              <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div id="mobile-services" class="hidden pl-4 space-y-1 pb-2">
              {serviceLinks.map((link) => (
                <a href={link.href} class="block text-sm text-gray-600 hover:text-accent py-1.5">{link.name}</a>
              ))}
            </div>
          </div>
        ) : item.name === "Locations" ? (
          <div>
            <button class="mobile-dropdown-btn w-full flex items-center justify-between font-heading text-lg tracking-wide text-primary py-2" data-target="mobile-locations">
              {item.name.toUpperCase()}
              <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div id="mobile-locations" class="hidden pl-4 space-y-1 pb-2">
              {locationLinks.map((link) => (
                <a href={link.href} class="block text-sm text-gray-600 hover:text-accent py-1.5">{link.name}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="block font-heading text-lg tracking-wide text-primary py-2">{item.name.toUpperCase()}</a>
        )
      ))}
      <a href="tel:9547275435" class="block bg-accent text-white font-heading text-lg tracking-wide px-6 py-3 rounded text-center mt-4">CALL NOW</a>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-dropdown-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const target = document.getElementById(targetId!);
      const arrow = btn.querySelector('svg');
      target?.classList.toggle('hidden');
      arrow?.classList.toggle('rotate-180');
    });
  });
</script>
