---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const { title, description = "Commercial Door Services — expert commercial door installation, repair & maintenance in Orlando & Miami, FL. 24/7 emergency service. Call (954) 727-5435.", keywords = "commercial door services, commercial door installation, commercial door repair, automatic doors, security doors, fire-rated doors, Orlando, Miami, FL, commercial door maintenance" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const breadcrumbItems = [{ name: "Home", url: "https://commercial-door-services.com/" }];
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
let currentPath = "https://commercial-door-services.com";
for (const segment of pathSegments) {
  currentPath += `/${segment}`;
  const name = segment.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
  breadcrumbItems.push({ name, url: currentPath });
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Commercial Door Services" />
    <meta property="og:image" content={new URL('/images/logo.png', Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/images/logo.png', Astro.site).href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.web3forms.com" />
    <link rel="dns-prefetch" href="https://www.google.com" />
    <link rel="dns-prefetch" href="https://www.gstatic.com" />
    <link rel="alternate" href={canonicalURL.href} hreflang="en" />
    <link rel="alternate" href={canonicalURL.href} hreflang="x-default" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Commercial Door Services",
      "description": "Expert commercial door installation, repair, and maintenance services in Orlando and Miami, FL. Automatic doors, security doors, and fire-rated doors.",
      "url": "https://commercial-door-services.com",
      "telephone": "+1-954-727-5435",
      "image": "https://commercial-door-services.com/images/logo.png",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Orlando",
        "addressRegion": "FL",
        "addressCountry": "US"
      },
      "areaServed": [
        { "@type": "City", "name": "Orlando" },
        { "@type": "City", "name": "Miami" }
      ],
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      },
      "sameAs": []
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems.map((item, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "name": item.name,
        "item": item.url
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Commercial Door Services",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Commercial Door Services",
        "telephone": "+1-954-727-5435",
        "url": "https://commercial-door-services.com"
      },
      "areaServed": [
        { "@type": "City", "name": "Orlando" },
        { "@type": "City", "name": "Miami" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Commercial Door Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Door Installation" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Door Repair" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Door Lock Services" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Hinge Repair & Replacement" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Lock Repair" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roller Replacement & Frame Repair" } }
        ]
      }
    })} />
  </head>
  <body class="font-body text-gray-800 antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
